# Copy to .env for local development.
# Used by sqlx-cli (for migrations) and the ledger-api binary.
DATABASE_URL=postgres://ledger:ledger@localhost:5432/ledger

# HTTP server bind address
LEDGER_BIND=127.0.0.1:8080

# tracing filter — see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html
RUST_LOG=ledger_api=info,ledger_db=info,tower_http=info,sqlx=warn
